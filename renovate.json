{
    "extends": [
        "config:recommended"
    ],
    "gitIgnoredAuthors": [
        "github-actions[bot]@users.noreply.github.com",
        "41898282+github-actions[bot]@users.noreply.github.com"
    ],
    "platformAutomerge": true,
    "rebaseWhen": "conflicted",
    "semanticCommits": "enabled",
    "semanticCommitScope": "deps",
    "enabledManagers": [
        "github-actions",
        "helm-values",
        "helmv3",
        "custom.regex"
    ],
    "pinDigests": true,
    "prHourlyLimit": 5,
    "prConcurrentLimit": 3,
    "timezone": "Europe/Berlin",
    "assignees": [
        "slydlake"
    ],
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update tag in values.yaml for linuxserver/wireguard",
            "managerFilePatterns": [
                "/^charts/wireguard/values\\.yaml$/"
            ],
            "matchStrings": [
                "repository:\\s+linuxserver/wireguard[\\s\\S]*?tag:\\s+['\"]?(?<currentValue>[^'\"\\s@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
            ],
            "depNameTemplate": "docker.io/linuxserver/wireguard",
            "datasourceTemplate": "docker"
        },
        {
            "customType": "regex",
            "description": "Update appVersion in Chart.yaml for wireguard",
            "managerFilePatterns": [
                "/^charts/wireguard/Chart\\.yaml$/"
            ],
            "matchStrings": [
                "appVersion:\\s+(?<currentValue>[^\\s]+)"
            ],
            "depNameTemplate": "docker.io/linuxserver/wireguard",
            "datasourceTemplate": "docker"
        },
        {
            "customType": "regex",
            "description": "Update appVersion in Chart.yaml",
            "managerFilePatterns": [
                "/^charts/.*/Chart\\.yaml$/"
            ],
            "matchStrings": [
                "appVersion:\\s+['\"]?(?<currentValue>[^'\"\\s]+)['\"]?\\s*#\\s*renovate:\\s*image=(?<packageName>[^\\s]+)"
            ],
            "depNameTemplate": "{{{packageName}}}",
            "datasourceTemplate": "docker"
        },
        {
            "customType": "regex",
            "description": "Update artifacthub.io/images in Chart.yaml",
            "managerFilePatterns": [
                "/^charts/.*/Chart\\.yaml$/"
            ],
            "matchStrings": [
                "image: (?<packageName>[^:]+):(?<currentValue>[^\\s]+)"
            ],
            "depNameTemplate": "{{{packageName}}}",
            "datasourceTemplate": "docker"
        }
    ],
    "packageRules": [
        {
            "description": "Disable helm-values for wireguard (handled by custom.regex)",
            "matchManagers": [
                "helm-values"
            ],
            "matchFileNames": [
                "charts/wireguard/values.yaml"
            ],
            "matchPackageNames": [
                "docker.io/linuxserver/wireguard"
            ],
            "enabled": false
        },
        {
            "description": "Wireguard regex versioning override",
            "matchManagers": [
                "custom.regex"
            ],
            "matchPackageNames": [
                "docker.io/linuxserver/wireguard"
            ],
            "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-r(?<prerelease>\\d+)-ls(?<build>\\d+)$"
        },
        {
            "description": "Group direct dependency updates per chart and target version",
            "matchManagers": [
                "helm-values",
                "custom.regex"
            ],
            "matchFileNames": [
                "charts/**"
            ],
            "groupName": "chart/{{{ replace '/samples' '' (replace 'charts/' '' parentDir) }}}/{{{depName}}}/{{#if (equals updateType 'digest')}}digest-{{{newDigestShort}}}{{else}}{{{newVersion}}}{{/if}}",
            "branchTopic": "chart-{{{ replace '/samples' '' (replace 'charts/' '' parentDir) }}}-{{{depNameSanitized}}}-{{#if (equals updateType 'digest')}}digest-{{{newDigestShort}}}{{else}}{{{newVersion}}}{{/if}}",
            "labels": [
                "dependencies",
                "renovate"
            ],
            "addLabels": [
                "{{#if isMajor}}major{{/if}}{{#if isMinor}}minor{{/if}}{{#if isPatch}}patch{{/if}}{{#if isDigest}}digest{{/if}}"
            ]
        },
        {
            "description": "Use short wireguard dependency name in direct update titles",
            "matchManagers": [
                "custom.regex"
            ],
            "matchFileNames": [
                "charts/wireguard/values.yaml",
                "charts/wireguard/Chart.yaml"
            ],
            "matchPackageNames": [
                "docker.io/linuxserver/wireguard"
            ],
            "groupName": "chart/wireguard/wireguard/{{#if (equals updateType 'digest')}}digest-{{{newDigestShort}}}{{else}}{{{newVersion}}}{{/if}}",
            "branchTopic": "chart-wireguard-wireguard-{{#if (equals updateType 'digest')}}digest-{{{newDigestShort}}}{{else}}{{{newVersion}}}{{/if}}"
        },
        {
            "description": "Group subchart updates per dependency with version-specific branch names",
            "matchManagers": [
                "helmv3"
            ],
            "matchFileNames": [
                "charts/**"
            ],
            "groupName": "subchart/{{{ replace '/samples' '' (replace 'charts/' '' parentDir) }}}/{{{depName}}}/{{#if (equals updateType 'digest')}}digest-{{{newDigestShort}}}{{else}}{{{newVersion}}}{{/if}}",
            "branchTopic": "subchart-{{{ replace '/samples' '' (replace 'charts/' '' parentDir) }}}-{{{depNameSanitized}}}-{{#if (equals updateType 'digest')}}digest-{{{newDigestShort}}}{{else}}{{{newVersion}}}{{/if}}",
            "labels": [
                "dependencies",
                "renovate"
            ],
            "addLabels": [
                "{{#if isMajor}}major{{/if}}{{#if isMinor}}minor{{/if}}{{#if isPatch}}patch{{/if}}{{#if isDigest}}digest{{/if}}"
            ]
        },
        {
            "description": "Group wordpress subchart updates per dependency to avoid long-lived grouped PRs",
            "matchManagers": [
                "helmv3"
            ],
            "matchFileNames": [
                "charts/wordpress/**"
            ],
            "groupName": "subchart/wordpress/{{{depName}}}/{{#if (equals updateType 'digest')}}digest-{{{newDigestShort}}}{{else}}{{{newVersion}}}{{/if}}",
            "branchTopic": "subchart-wordpress-{{{depNameSanitized}}}-{{#if (equals updateType 'digest')}}digest-{{{newDigestShort}}}{{else}}{{{newVersion}}}{{/if}}"
        },
        {
            "description": "Per-package GitHub Actions workflow updates with version-specific branches",
            "matchManagers": [
                "github-actions"
            ],
            "matchFileNames": [
                ".github/workflows/**"
            ],
            "branchTopic": "github-actions-{{{depNameSanitized}}}-{{#if (equals updateType 'digest')}}digest-{{{newDigestShort}}}{{else}}{{{newVersion}}}{{/if}}",
            "labels": [
                "dependencies",
                "renovate"
            ],
            "addLabels": [
                "{{#if isMajor}}major{{/if}}{{#if isMinor}}minor{{/if}}{{#if isPatch}}patch{{/if}}{{#if isDigest}}digest{{/if}}"
            ],
            "semanticCommitType": "chore"
        },
        {
            "description": "Chart bump mapping: subchart (helmv3) major dependency bump -> chart MINOR bump (feat)",
            "matchManagers": [
                "helmv3"
            ],
            "matchFileNames": [
                "charts/**"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "semanticCommitType": "feat"
        },
        {
            "description": "Chart bump mapping: subchart (helmv3) minor/patch/digest -> chart PATCH bump (fix)",
            "matchManagers": [
                "helmv3"
            ],
            "matchFileNames": [
                "charts/**"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch",
                "digest"
            ],
            "semanticCommitType": "fix"
        },
        {
            "description": "Chart bump mapping: direct dependency major -> chart MAJOR bump (breaking feat!)",
            "matchManagers": [
                "helm-values",
                "custom.regex"
            ],
            "matchFileNames": [
                "charts/**"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "semanticCommitType": "feat",
            "commitMessagePrefix": "feat!:",
            "commitBody": "BREAKING CHANGE: {{{depName}}} major update to {{{newVersion}}}"
        },
        {
            "description": "Chart bump mapping: direct dependency minor -> chart MINOR bump (feat)",
            "matchManagers": [
                "helm-values",
                "custom.regex"
            ],
            "matchFileNames": [
                "charts/**"
            ],
            "matchUpdateTypes": [
                "minor"
            ],
            "semanticCommitType": "feat"
        },
        {
            "description": "Chart bump mapping: direct dependency patch/digest -> chart PATCH bump (fix)",
            "matchManagers": [
                "helm-values",
                "custom.regex"
            ],
            "matchFileNames": [
                "charts/**"
            ],
            "matchUpdateTypes": [
                "patch",
                "digest"
            ],
            "semanticCommitType": "fix"
        },
        {
            "description": "Auto-merge minor, patch, and digest updates",
            "matchManagers": [
                "github-actions",
                "helm-values",
                "custom.regex",
                "helmv3"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch",
                "digest"
            ],
            "addLabels": [
                "automerge"
            ],
            "automerge": true,
            "automergeType": "pr"
        },
        {
            "description": "Never auto-merge major updates",
            "matchManagers": [
                "github-actions",
                "helm-values",
                "custom.regex",
                "helmv3"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "addLabels": [
                "major"
            ],
            "automerge": false
        }
    ]
}
